      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false, "showThresholdMarkers": true, "sizing": "auto"
      },
      "pluginVersion": "12.2.0",
      "targets": [
        {
          "format": "table",
          "rawSql": "WITH run AS (\n  SELECT started_at, networks FROM scrape_runs\n  WHERE id = (SELECT MAX(id) FROM scrape_runs)\n),\ntotal AS (\n  SELECT COUNT(*) AS n FROM groups g, run\n  WHERE CASE\n    WHEN run.networks = 'ALL' THEN true\n    WHEN run.networks = 'COMMUNITY' THEN g.pro_network = 'community'\n    WHEN run.networks = 'DISCOVERED' THEN g.pro_network IN ('discovered_meetup', 'discovered_luma')\n    ELSE g.pro_network = ANY(string_to_array(run.networks, ' '))\n  END\n),\ndone AS (\n  SELECT COUNT(*) AS n FROM scrape_log\n  WHERE scraped_at >= (SELECT started_at FROM run)\n)\nSELECT ROUND(100.0 * done.n / NULLIF(total.n, 0), 1) AS value\nFROM done, total",
          "refId": "A"
        }
      ],
      "title": "Run % Complete",
      "type": "gauge"
    },
    {
      "datasource": { "type": "postgres", "uid": "P959179BC9356FFE3" },
      "fieldConfig": {
        "defaults": {
