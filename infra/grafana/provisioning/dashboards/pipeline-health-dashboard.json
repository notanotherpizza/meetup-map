    {
      "datasource": { "type": "postgres", "uid": "P959179BC9356FFE3" },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "max": 100, "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 75 }
            ]
          },
