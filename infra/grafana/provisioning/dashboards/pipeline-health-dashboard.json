      "id": 6,
      "options": {
        "cellHeight": "sm", "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "started_at" }]
      },
      "pluginVersion": "12.2.0",
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  r.id,\n  r.networks AS mode,\n  r.started_at,\n  COUNT(l.id) AS groups_scraped,\n  COUNT(l.id) FILTER (WHERE l.error IS NOT NULL) AS errors\nFROM scrape_runs r\nLEFT JOIN scrape_log l ON l.run_id = r.id\nGROUP BY r.id, r.networks, r.started_at\nORDER BY r.started_at DESC\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Recent Runs",
      "type": "table"
    },

