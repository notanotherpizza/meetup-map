        {
          "format": "table",
          "rawSql": "-- Groups seeded = scrape_log rows since run started (proxy: groups consumed from Kafka)\nSELECT COUNT(*) AS value\nFROM scrape_log\nWHERE scraped_at >= (SELECT started_at FROM scrape_runs WHERE id = (SELECT MAX(id) FROM scrape_runs))",
          "refId": "A"
        }
      ],
      "title": "Groups Scraped (this run)",
      "type": "stat"
