        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH run AS (\n  SELECT started_at, networks FROM scrape_runs WHERE id = (SELECT MAX(id) FROM scrape_runs)\n),\nrate AS (\n  SELECT COUNT(*) / NULLIF(EXTRACT(EPOCH FROM (MAX(last_scraped_at) - MIN(last_scraped_at))), 0) as groups_per_sec\n  FROM groups\n  WHERE last_scraped_at > NOW() - INTERVAL '30 minutes'\n  AND last_scraped_at >= (SELECT started_at FROM run)\n),\nremaining AS (\n  SELECT COUNT(*) as n\n  FROM groups\n  WHERE pro_network = ANY(\n    SELECT unnest(string_to_array(networks, ',')) FROM run\n  )\n  AND last_scraped_at < (SELECT started_at FROM run)\n)\nSELECT ROUND(remaining.n / NULLIF(rate.groups_per_sec, 0)) as value\nFROM rate, remaining",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Estimated Time Remaining",
      "type": "stat"
    },
