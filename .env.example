# ── Aiven Kafka ──────────────────────────────────────────────────────────────
# Find these in Aiven console → your Kafka service → Connection information
KAFKA_BOOTSTRAP_SERVERS=your-service.aivencloud.com:12345
KAFKA_SSL_CA_FILE=./certs/ca.pem
KAFKA_SSL_CERT_FILE=./certs/service.cert
KAFKA_SSL_KEY_FILE=./certs/service.key

# ── Aiven Postgres ────────────────────────────────────────────────────────────
# Find in Aiven console → your Postgres service → Connection information → URI
POSTGRES_URI=postgres://avnadmin:password@your-pg.aivencloud.com:12345/defaultdb?sslmode=require

# ── Topic names ───────────────────────────────────────────────────────────────
TOPIC_GROUPS_TO_SCRAPE=groups-to-scrape
TOPIC_GROUPS_RAW=groups-raw
TOPIC_EVENTS_RAW=events-raw

# ── Scraping behaviour ────────────────────────────────────────────────────────
# Pro network slugs to seed — space-separated, add more later
PRO_NETWORKS=pydata
# Max events to scrape per group (set to 0 for unlimited)
MAX_EVENTS_PER_GROUP=50
# Seconds to wait between Meetup requests (be polite)
REQUEST_DELAY_SECONDS=1.5
# Use Playwright fallback if API fails?
PLAYWRIGHT_FALLBACK=true
